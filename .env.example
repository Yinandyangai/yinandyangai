# ─── Supabase ────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only, used for admin ops if needed

# ─── AI providers (at least one — leave both empty to run in mock mode) ──────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Stripe (Phase 4 — billing) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
